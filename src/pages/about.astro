---
import BaseLayout from "../layouts/BaseLayout.astro";

const randomNotes = [
  "I spend a lot of time messing around with mech interp. I am a bit bearish that it is feasible, and alignment seems more probable",
  "I like getting good at things until I can do them intuitively (that's why physics is so satisfying).",
  "I keep a small booklet of ideas and usually rotate through a few of them every month.",
  "I use Ghostty and VS Code completely blacked out",
  "I like elegantly designed card tricks and board games"
];

const beliefs = [
  "my theory is that if I get better at reflecting on my implementation of advice, and figuring out what I am bad at, I will recursively improve",
  "most people do much more performative stuff than they think. Humanity's bar for what is performative is surprisingly high",
  "Cool people make life feel exciting",
  "Amor fati",
  "bci/acc"
];

const favoriteTheorems = [
  "Godel's incompleteness theorem",
  "the second law of thermodynamics",
  "Cantor's diagonal argument"
];
---

<BaseLayout
  title="About | Naman Chetwani"
  description="About Naman Chetwani."
>
  <main class="page">
    <div class="page-top">
      <nav class="top-nav" aria-label="Primary">
        <a class="nav-link" href="/" data-echo="Naman Chetwani">Naman Chetwani</a>
        <a class="nav-link current" href="/about" data-echo="About">About</a>
        <a class="nav-link" href="/things-ive-done" data-echo="Things I've Done">Things I've Done</a>
        <a class="nav-link" href="/reading" data-echo="Reading">Reading</a>
        <a class="nav-link" href="/wrdn" data-echo="wrdn">wrdn</a>
      </nav>
    </div>

    <article class="essay about-essay">
      <h1>About</h1>

      <h2>Things I believe:</h2>
      <ul class="plain-list about-list">
        {beliefs.map((belief) => (
          <li>
            {belief === "bci/acc" ? (
              <a
                href="https://blog.oceanprotocol.com/bci-acc-a-path-to-balance-ai-superintelligence-80bb6f32e39c"
                target="_blank"
                rel="noreferrer"
              >
                {belief}
              </a>
            ) : (
              belief
            )}
          </li>
        ))}
      </ul>

      <h2>My favorite theorems:</h2>
      <ul class="plain-list about-list">
        {favoriteTheorems.map((theorem) => (
          <li>
            {theorem === "the second law of thermodynamics" ? (
              <a
                href="https://www.lesswrong.com/posts/QkX2bAkwG2EpGvNug/the-second-law-of-thermodynamics-and-engines-of-cognition"
                target="_blank"
                rel="noreferrer"
              >
                {theorem}
              </a>
            ) : (
              theorem
            )}
          </li>
        ))}
      </ul>

      <div class="about-notes">
        {randomNotes.map((note) => (
          <p>{note}</p>
        ))}
      </div>

      <p>
        I subscribe to
        <a href="http://sl4.org/crocker.html" target="_blank" rel="noreferrer"> Crocker&apos;s Rules</a>.
      </p>

      <p>
        If you want to reach me, email
        <a href="mailto:naman.chetwani@gmail.com"> naman.chetwani@gmail.com</a>
        (my threshold for reaching out is rlly low).
      </p>
    </article>
  </main>
</BaseLayout>
