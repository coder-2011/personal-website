---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    title: "wrdn",
    paragraphs: [
      "Building wrdn, an AI accountability system for your life. It watches your day through ambient audio and visual context, builds a long-term model of your goals and values, and tells you when you're drifting from what actually matters to you.",
      "It helps you make decisions according to the context spanning your life, and proactively executes commands through personal agents.",
      "I build the stack from kernels to hardware."
    ]
  },
  {
    title: "STRATUS UAV: Optimizing Prescribed Burning using UAVs and Predictive Modeling",
    paragraphs: [
      "Led development of patent-pending autonomous UAV to mitigate wildfire spread. From scratch, 3D-printed a VTOL aircraft designed to conduct autonomous backburning, achieving 15 km range with 1.2 hour endurance, solving the biggest issues in the field:",
      "I built in 7 months what they built in 9 years."
    ],
    bullets: [
      "Cost: around $16k/day for helicopters, custom built helicopters, and pilots",
      "Safety: pilot liability",
      "Lower price: by 5x",
      "Higher range: by a factor of 3x over the closest drone competitor"
    ],
    images: [
      {
        src: "/projects/stratus-poster-real.png",
        alt: "STRATUS UAV project poster showing the wildfire UAV, modeling system, and project overview.",
        caption: "STRATUS project poster"
      },
      {
        src: "/projects/stratus-poster.jpg",
        alt: "STRATUS UAV aircraft photo.",
        caption: "STRATUS UAV airframe"
      }
    ]
  },
  {
    title: "SBON (Strategic-Blackline-Optimization-Engine)",
    paragraphs: [
      "Built a wildfire prediction foundational model that broke SOTA and created the first ML approach to optimizing prescribed burns.",
      "SBON uses a tri-branch multimodal architecture over 13 input modalities spanning fire imagery, weather, and geography, with ConvNeXt and SSMs as encoders, feeding into a larger SSM to create a 4-hour fire-mask prediction.",
      "We treat the wildfire foundational model as an environment, where we autoregressively rollout to 48 hours to get a longer scale prediction. We then use PPO to optimize the placement of prescribed burns, turning a workflow still driven largely by checklists and operator intuition into an optimization problem."
    ],
    image: {
      src: "/projects/sbon-diagram.png",
      alt: "SBON system diagram showing the terrain, weather, fire, Mamba core, and decoder pipeline.",
      caption: "SBON architecture diagram"
    },
    links: [
      {
        href: "https://github.com/coder-2011/Strategic-Blackline-Optimization-Network",
        label: "GitHub repo"
      }
    ]
  },
  {
    title: "No Circles",
    paragraphs: [
      "Built no-circles.com, a website-first personalized daily newsletter that learns from what each reader actually responds to.",
      "The system keeps a memory of the user, builds a brief from that memory, and updates future issues from replies and feedback to help teach the person about tangential fields they know little about. Scaled to triple-digit users 3 weeks from inception"
    ],
    image: {
      src: "/reading/no-circles.png",
      alt: "No Circles product image.",
      caption: "No Circles"
    },
    links: [
      { href: "https://no-circles.com", label: "no-circles.com" },
      { href: "https://github.com/coder-2011/no-circles", label: "GitHub repo" }
    ]
  },
  {
    title: "Science fair results",
    paragraphs: [
      "Placed 2nd in the California State Science Fair, 1st @ regionals and won 5 awards building PHEONIX UAV for early wildfire detection:",
      "1st in category, 1st in fair, Henkel aerospace award, 1 of 3 selected for national competition, 1 out of 200 nationally winning Junior Lemelson-MIT Inventor Award, and 1 of 20 selected for state level competition."
    ],
    image: {
      src: "/projects/phoenix-uav-poster.png",
      alt: "PHEONIX UAV project poster for early wildfire detection.",
      caption: "PHEONIX UAV poster"
    }
  },
  {
    title: "Competitions",
    paragraphs: [
      "Competed in various competitive programming and physics competitions, ultimately developing skills achieving USACO Gold and qualifying scores on the F=MA exam, which is top 5% nationally.",
      "I also competed in CALICO, Harker Physics Invitational, Harker Programming Invitational, and held a top 30 placement in the nation in MSPF Debate, reaching elimination rounds in national-circuit tournaments like Stanford and TOC."
    ]
  },
  {
    title: "Self-study",
    paragraphs: [
      "Independently studied mathematics from high school precalculus to multivariable calculus and linear algebra, as well as ML and transformer theory, in under a year.",
      "A lot of that came from wanting to compress ideas until they felt intuitive instead of merely familiar."
    ]
  }
];
---

<BaseLayout
  title="Things I've Done | Naman Chetwani"
  description="Selected projects and accomplishments by Naman Chetwani."
>
  <main class="page">
    <div class="page-top">
      <nav class="top-nav" aria-label="Primary">
        <a class="nav-link" href="/">Naman Chetwani</a>
        <a class="nav-link" href="/about">About</a>
        <a class="nav-link current" href="/things-ive-done">Things I've Done</a>
        <a class="nav-link" href="/reading">Reading</a>
        <a class="nav-link" href="/wrdn">wrdn</a>
      </nav>
    </div>

    <article class="essay about-essay">
      <h1>Things I&apos;ve Done</h1>

      <div class="project-stack">
        <section class="project-panel">
          <h2>Contract Work</h2>
          <p>
            Under contract building machines for fire tech companies. manafacturing fireballs
          </p>
        </section>

        {projects.map((project) => (
          <section class="project-panel">
            <h2>{project.title}</h2>
            {project.images && (
              <div class:list={["project-gallery", project.images.length > 1 && "project-gallery-multi"]}>
                {project.images.map((image) => (
                  <figure class="project-figure">
                    <img src={image.src} alt={image.alt} loading="lazy" />
                    {image.caption && <figcaption>{image.caption}</figcaption>}
                  </figure>
                ))}
              </div>
            )}
            {project.image && (
              <figure class="project-figure">
                <img src={project.image.src} alt={project.image.alt} loading="lazy" />
                {project.image.caption && <figcaption>{project.image.caption}</figcaption>}
              </figure>
            )}
            {project.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            {project.bullets && (
              <ul class="plain-list project-bullets">
                {project.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            )}
            {project.links && (
              <p class="project-links">
                {project.links.map((link, index) => (
                  <>
                    {index > 0 && <span class="link-divider"> · </span>}
                    <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
                  </>
                ))}
              </p>
            )}
          </section>
        ))}
      </div>
    </article>
  </main>
</BaseLayout>
