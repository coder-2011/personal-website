---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    title: "wrdn",
    paragraphs: [
      "Built wrdn, an AI accountability system for your life. It watches your day through ambient audio and visual context, builds a long-term model of your goals and values, and tells you when you're drifting from what you said actually matters.",
      "It helps you make decisions according to the context spanning your life, and proactively executes commands through personal agents."
    ]
  },
  {
    title: "STRATUS UAV: Optimizing Prescribed Burning using UAVs and Predictive Modeling",
    paragraphs: [
      "Led development of patent-pending autonomous UAV to mitigate wildfire spread. From scratch, 3D-printed a VTOL aircraft designed to conduct autonomous backburning, achieving 15 km range with 1.2 hour endurance.",
      "The goal was to solve the biggest issues in the field: cost, pilot liability, lower price, and higher range than the closest drone competitor."
    ],
    image: {
      src: "/projects/stratus-poster.jpg",
      alt: "STRATUS UAV project poster showing the wildfire UAV, modeling system, and project overview.",
      caption: "STRATUS project poster"
    },
    bullets: [
      "Cost: around $16k/day for helicopters, custom built helicopters, and pilots",
      "Safety: pilot liability",
      "Lower price: by 5x",
      "Higher range: by a factor of 3x over the closest drone competitor"
    ]
  },
  {
    title: "SBON (Strategic-Blackline-Optimization-Engine)",
    paragraphs: [
      "Engineered an AI-driven ecological tool designed to prevent catastrophic wildfires. Utilizing a tri-branch architecture with state-space model architecture and ConvNeXt, the engine analyzes environmental variables to pinpoint ideal locations for prescribed burns.",
      "The 13 types of input data are split into current fire imaging, text-based weather data, and less dynamic geography data. Each category is initially processed through its own specialized model, then fused through a stronger state-space model before being turned into an output fire mask for prediction and simulation."
    ]
  },
  {
    title: "No Circles",
    paragraphs: [
      "Built no-circles.com, a website-first personalized daily newsletter that learns from what each reader actually responds to.",
      "The system keeps a text-first memory of the user, builds a brief from that memory, and updates future issues from replies and feedback instead of sending everyone the same links."
    ],
    links: [
      { href: "https://no-circles.com", label: "no-circles.com" },
      { href: "https://github.com/coder-2011/no-circles", label: "GitHub repo" }
    ]
  },
  {
    title: "Science fair results",
    paragraphs: [
      "Placed 2nd in the California State Science Fair, 1st at regionals, and won 5 awards building PHEONIX UAV for early wildfire detection.",
      "That included 1st in category, 1st in fair, the Henkel aerospace award, selection for national competition, the Junior Lemelson-MIT Inventor Award, and selection for state-level competition."
    ],
    image: {
      src: "/projects/phoenix-uav-poster.png",
      alt: "PHEONIX UAV project poster for early wildfire detection.",
      caption: "PHEONIX UAV poster"
    }
  },
  {
    title: "Competitions",
    paragraphs: [
      "Competed in various competitive programming and physics competitions, ultimately developing skills achieving USACO Gold and qualifying scores on the F=MA exam, which is top 5% nationally.",
      "I also competed in CALICO, Harker Physics Invitational, Harker Programming Invitational, and held a top 30 placement in the nation in MSPF Debate, reaching elimination rounds in national-circuit tournaments like Stanford and TOC."
    ]
  },
  {
    title: "Self-study",
    paragraphs: [
      "Independently studied mathematics from high school precalculus to multivariable calculus and linear algebra, as well as ML and transformer theory, in under a year.",
      "A lot of that came from wanting to compress ideas until they felt intuitive instead of merely familiar."
    ]
  }
];
---

<BaseLayout
  title="Things I've Done | Naman Chetwani"
  description="Selected projects and accomplishments by Naman Chetwani."
>
  <main class="page">
    <div class="page-top">
      <nav class="top-nav" aria-label="Primary">
        <a class="nav-link" href="/">Naman Chetwani</a>
        <a class="nav-link current" href="/things-ive-done">Things I've Done</a>
        <a class="nav-link" href="/reading">Reading</a>
      </nav>
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch theme">
        Light mode
      </button>
    </div>

    <article class="essay about-essay">
      <h1>Things I&apos;ve Done</h1>

      <p>
        awards, accomplishments, and projects I&apos;m proud of.
      </p>

      <div class="project-stack">
        {projects.map((project) => (
          <section class="project-panel">
            <h2>{project.title}</h2>
            {project.image && (
              <figure class="project-figure">
                <img src={project.image.src} alt={project.image.alt} loading="lazy" />
                {project.image.caption && <figcaption>{project.image.caption}</figcaption>}
              </figure>
            )}
            {project.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            {project.bullets && (
              <ul class="plain-list project-bullets">
                {project.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            )}
            {project.links && (
              <p class="project-links">
                {project.links.map((link, index) => (
                  <>
                    {index > 0 && <span class="link-divider"> · </span>}
                    <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
                  </>
                ))}
              </p>
            )}
          </section>
        ))}
      </div>
    </article>
  </main>
</BaseLayout>
