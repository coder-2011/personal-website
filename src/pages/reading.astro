---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Reading | Naman Chetwani"
  description="Reading page for Naman Chetwani."
>
  <main class="page">
    <div class="page-top">
      <nav class="top-nav" aria-label="Primary">
        <a class="nav-link" href="/" data-echo="Naman Chetwani">Naman Chetwani</a>
        <a class="nav-link" href="/about" data-echo="About">About</a>
        <a class="nav-link" href="/things-ive-done" data-echo="Things I've Done">Things I've Done</a>
        <a class="nav-link current" href="/reading" data-echo="Reading">Reading</a>
        <a class="nav-link" href="/wrdn" data-echo="wrdn">wrdn</a>
      </nav>
    </div>

    <article class="essay about-essay">
      <h1>Reading</h1>

      <p>
        I mainly read things completely unrelated to what I know about.
      </p>

      <p>
        Anything that feels like it might expand my worldview
      </p>

      <section class="reading-section" aria-labelledby="favorite-writing">
        <h2 id="favorite-writing">Favorite writing</h2>
        <p class="section-note">I really like pretty book covers.</p>

        <div class="reading-grid">
          <a
            class="reading-card"
            href="https://www.ynharari.com/book/sapiens/"
            target="_blank"
            rel="noreferrer"
          >
            <img
              src="/reading/sapiens.jpg"
              alt="Cover of Sapiens: A Brief History of Humankind"
              loading="lazy"
            />
            <span class="reading-title">Sapiens: A Brief History of Humankind</span>
            <span class="reading-meta">Yuval Noah Harari</span>
          </a>

          <a
            class="reading-card"
            href="https://www.hachettebookgroup.com/titles/douglas-r-hofstadter/godel-escher-bach/9780465026562/"
            target="_blank"
            rel="noreferrer"
          >
            <img
              src="/reading/geb.jpg"
              alt="Cover of Gödel, Escher, Bach: An Eternal Golden Braid"
              loading="lazy"
            />
            <span class="reading-title">Gödel, Escher, Bach: An Eternal Golden Braid</span>
            <span class="reading-meta">Douglas R. Hofstadter</span>
          </a>

          <a
            class="reading-card"
            href="https://press.stripe.com/the-art-of-doing-science-and-engineering"
            target="_blank"
            rel="noreferrer"
          >
            <img
              src="/reading/hamming.jpg"
              alt="Cover of The Art of Doing Science and Engineering: Learning to Learn"
              loading="lazy"
            />
            <span class="reading-title">The Art of Doing Science and Engineering: Learning to Learn</span>
            <span class="reading-meta">Richard Hamming</span>
          </a>

          <a
            class="reading-card"
            href="https://www.lesswrong.com/rationality"
            target="_blank"
            rel="noreferrer"
          >
            <img
              src="/reading/sequences.png"
              alt="Cover image for The Sequences"
              loading="lazy"
            />
            <span class="reading-title">The Sequences</span>
            <span class="reading-meta">LessWrong</span>
          </a>
        </div>

        <h2>Favorite morsels of wisdom</h2>
        <ul class="plain-list wisdom-list">
          <li>
            <a href="https://paulgraham.com/greatwork.html" target="_blank" rel="noreferrer">
              Great Work
            </a>
            <span class="wisdom-meta">Paul Graham</span>
          </li>
          <li>
            <a
              href="https://blog.samaltman.com/the-days-are-long-but-the-decades-are-short"
              target="_blank"
              rel="noreferrer"
            >
              The Days Are Long but the Decades Are Short
            </a>
            <span class="wisdom-meta">Sam Altman</span>
          </li>
        </ul>
      </section>

      <h2>Other recurring inputs</h2>
      <ul class="plain-list">
        <li>LessWrong</li>
        <li>Nietzsche</li>
        <li>Two Minute Papers</li>
        <li>Lex Fridman</li>
        <li>20VC</li>
      </ul>
    </article>
  </main>
</BaseLayout>
