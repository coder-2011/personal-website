---
const title = "TROLL TERMINAL";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: dark;
        --hot: #ff2bd6;
        --acid: #ccff00;
        --aqua: #00f7ff;
        --sun: #ffef00;
        --ink: #07000f;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        min-height: 100%;
      }

      body {
        margin: 0;
        overflow: hidden;
        background:
          linear-gradient(transparent 95%, rgba(255, 255, 255, 0.35) 96%),
          linear-gradient(90deg, transparent 95%, rgba(255, 255, 255, 0.3) 96%),
          radial-gradient(circle at 20% 20%, #ff00d4, transparent 28%),
          radial-gradient(circle at 84% 18%, #00ffe1, transparent 26%),
          radial-gradient(circle at 50% 100%, #fbff00, transparent 34%),
          #120019;
        background-size:
          38px 38px,
          38px 38px,
          auto,
          auto,
          auto,
          auto;
        color: white;
        font-family: "Courier New", Monaco, monospace;
        animation: hue-party 2.6s linear infinite;
      }

      body::before {
        content: "";
        position: fixed;
        inset: -50%;
        pointer-events: none;
        background:
          repeating-conic-gradient(
            from 0deg,
            rgba(255, 43, 214, 0.18) 0deg 10deg,
            rgba(0, 247, 255, 0.18) 10deg 20deg,
            rgba(204, 255, 0, 0.18) 20deg 30deg
          );
        mix-blend-mode: screen;
        animation: spin 9s linear infinite;
      }

      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background: repeating-linear-gradient(
          0deg,
          rgba(0, 0, 0, 0.2) 0 2px,
          transparent 2px 5px
        );
      }

      button,
      textarea {
        font: inherit;
      }

      .troll-page {
        position: relative;
        z-index: 1;
        display: grid;
        place-items: center;
        min-height: 100vh;
        padding: clamp(0.75rem, 3vw, 2rem);
      }

      .chat-shell {
        display: grid;
        grid-template-rows: auto 1fr auto;
        width: min(100%, 900px);
        height: min(92vh, 780px);
        border: 5px ridge var(--sun);
        background:
          linear-gradient(135deg, rgba(0, 0, 0, 0.86), rgba(42, 0, 54, 0.88)),
          repeating-linear-gradient(
            45deg,
            rgba(255, 255, 255, 0.06) 0 8px,
            rgba(0, 0, 0, 0.06) 8px 16px
          );
        box-shadow:
          0 0 0 6px #ff2bd6,
          0 0 0 12px #00f7ff,
          0 0 34px #ffef00,
          inset 0 0 40px rgba(255, 43, 214, 0.42);
      }

      .marquee {
        overflow: hidden;
        border-bottom: 4px double var(--acid);
        background: #000;
        color: var(--acid);
        text-shadow: 3px 0 #ff2bd6, -3px 0 #00f7ff;
        white-space: nowrap;
      }

      .marquee span {
        display: inline-block;
        min-width: 100%;
        padding: 0.7rem 0;
        font-weight: 900;
        letter-spacing: 0;
        animation: crawl 10s linear infinite;
      }

      .arena {
        position: relative;
        overflow: hidden;
        min-height: 0;
      }

      .arena::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(120deg, transparent 0 49%, rgba(0, 247, 255, 0.3) 50%, transparent 51%),
          linear-gradient(60deg, transparent 0 49%, rgba(255, 239, 0, 0.24) 50%, transparent 51%);
        background-size: 54px 54px;
        transform: perspective(340px) rotateX(64deg) translateY(26%);
        transform-origin: bottom;
      }

      .messages {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
        height: 100%;
        overflow-y: auto;
        padding: 1.25rem;
        scroll-behavior: smooth;
      }

      .empty-shout {
        margin: auto;
        max-width: 18ch;
        color: var(--sun);
        font-size: clamp(2rem, 8vw, 5.5rem);
        font-weight: 900;
        line-height: 0.9;
        text-align: center;
        text-shadow:
          5px 5px #ff2bd6,
          -5px -3px #00f7ff,
          0 0 20px #ccff00;
        transform: rotate(-3deg);
      }

      .message {
        max-width: min(78ch, 92%);
        padding: 0.9rem 1rem;
        border: 3px solid #fff;
        color: #fff;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
        image-rendering: pixelated;
        text-shadow: 2px 0 #000, 0 2px #000;
        box-shadow: 6px 6px 0 #000;
      }

      .message.user {
        align-self: flex-end;
        background: repeating-linear-gradient(90deg, #ff2bd6 0 10px, #7b00ff 10px 20px);
        border-color: var(--sun);
      }

      .message.assistant {
        align-self: flex-start;
        background:
          repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.18) 0 4px, transparent 4px 8px),
          linear-gradient(135deg, #00a6ff, #16ff72, #ffef00);
        color: #120019;
        font-weight: 900;
        text-shadow: 2px 2px #fff, -2px 0 #ff2bd6;
      }

      .loading {
        display: none;
        padding: 0 1.25rem 0.7rem;
        color: var(--acid);
        font-weight: 900;
        text-shadow: 2px 0 #ff2bd6;
      }

      .loading.is-visible {
        display: block;
      }

      .loading span {
        display: inline-block;
        animation: bounce 0.54s steps(2, end) infinite;
      }

      .chat-form {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 0.75rem;
        padding: 0.9rem;
        border-top: 4px double var(--hot);
        background: rgba(0, 0, 0, 0.82);
      }

      textarea {
        min-height: 4.25rem;
        max-height: 10rem;
        resize: vertical;
        border: 4px inset var(--aqua);
        border-radius: 0;
        padding: 0.8rem;
        background: #050005;
        color: var(--acid);
        caret-color: var(--hot);
        outline: 0;
        text-shadow: 2px 0 #5b00ff;
      }

      textarea:focus {
        box-shadow: 0 0 0 4px var(--sun);
      }

      button {
        min-width: 7rem;
        border: 4px outset var(--sun);
        border-radius: 0;
        background: repeating-linear-gradient(45deg, var(--sun) 0 8px, var(--hot) 8px 16px);
        color: #000;
        font-weight: 900;
        cursor: pointer;
        text-shadow: 1px 1px #fff;
      }

      button:disabled {
        filter: grayscale(1);
        cursor: wait;
      }

      .error {
        min-height: 1.25rem;
        padding: 0 0.9rem 0.8rem;
        background: rgba(0, 0, 0, 0.82);
        color: #ffdf00;
        font-weight: 900;
      }

      @keyframes hue-party {
        to {
          filter: hue-rotate(360deg) saturate(1.35);
        }
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      @keyframes crawl {
        from {
          transform: translateX(100%);
        }
        to {
          transform: translateX(-100%);
        }
      }

      @keyframes bounce {
        50% {
          transform: translateY(-0.3rem) rotate(4deg);
        }
      }

      @media (max-width: 640px) {
        .chat-shell {
          height: 96vh;
        }

        .chat-form {
          grid-template-columns: 1fr;
        }

        button {
          min-height: 3.25rem;
        }
      }
    </style>
  </head>
  <body>
    <audio id="troll-audio" src="/troll-loop.mp3" autoplay loop muted playsinline preload="auto"></audio>
    <main class="troll-page">
      <section class="chat-shell" aria-label="Troll chat">
        <div class="marquee" aria-hidden="true">
          <span>WELCOME TO TROLL TERMINAL 1998 * HONK HONK * WIREZ ONLINE * </span>
        </div>
        <div class="arena">
          <div id="messages" class="messages" aria-live="polite">
            <div class="empty-shout">TROLL BOT</div>
          </div>
        </div>
        <div id="loading" class="loading" aria-live="polite">
          <span>LOADING</span> <span>▮</span><span>▯</span><span>▮</span>
        </div>
        <form id="chat-form" class="chat-form">
          <textarea
            id="prompt"
            name="prompt"
            autocomplete="off"
            placeholder="type into the clown machine..."
            required></textarea>
          <button id="send" type="submit">BLAST</button>
        </form>
        <div id="error" class="error" role="status"></div>
      </section>
    </main>
    <script>
      const storageKey = "naman-troll-chat-v1";
      const messagesEl = document.querySelector("#messages");
      const form = document.querySelector("#chat-form");
      const promptEl = document.querySelector("#prompt");
      const sendEl = document.querySelector("#send");
      const loadingEl = document.querySelector("#loading");
      const errorEl = document.querySelector("#error");
      const audio = document.querySelector("#troll-audio");
      const audioStartSeconds = 10;

      let messages = [];
      let busy = false;
      let audioUnlocked = false;

      const save = () => {
        localStorage.setItem(storageKey, JSON.stringify(messages));
      };

      const scrollDown = () => {
        messagesEl.scrollTop = messagesEl.scrollHeight;
      };

      const startAudio = (loud = false) => {
        if (!(audio instanceof HTMLAudioElement)) {
          return;
        }

        if (audio.currentTime < audioStartSeconds) {
          audio.currentTime = audioStartSeconds;
        }

        audioUnlocked = audioUnlocked || loud;
        audio.volume = 0.55;
        audio.muted = !audioUnlocked;
        audio
          .play()
          .then(() => {
            audio.muted = false;
            audioUnlocked = true;
          })
          .catch(() => {});
      };

      const keepAudioAlive = () => {
        if (audio instanceof HTMLAudioElement && audio.paused) {
          startAudio(audioUnlocked);
        }
      };

      const render = () => {
        messagesEl.textContent = "";

        if (!messages.length) {
          const empty = document.createElement("div");
          empty.className = "empty-shout";
          empty.textContent = "TROLL BOT";
          messagesEl.append(empty);
          return;
        }

        for (const message of messages) {
          const node = document.createElement("div");
          node.className = `message ${message.role}`;
          node.textContent = message.content;
          messagesEl.append(node);
        }

        scrollDown();
      };

      const setBusy = (value) => {
        busy = value;
        sendEl.disabled = value;
        promptEl.disabled = value;
        loadingEl.classList.toggle("is-visible", value);
      };

      const load = () => {
        try {
          const stored = JSON.parse(localStorage.getItem(storageKey) || "[]");

          if (Array.isArray(stored)) {
            messages = stored.filter(
              (message) =>
                message &&
                (message.role === "user" || message.role === "assistant") &&
                typeof message.content === "string"
            );
          }
        } catch {
          messages = [];
        }

        render();
      };

      const appendAssistantChunk = (chunk) => {
        const last = messages[messages.length - 1];

        if (last?.role === "assistant") {
          last.content += chunk;
        } else {
          messages.push({ role: "assistant", content: chunk });
        }

        save();
        render();
      };

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        startAudio(true);

        if (busy) {
          return;
        }

        const content = promptEl.value.trim();

        if (!content) {
          return;
        }

        errorEl.textContent = "";
        promptEl.value = "";
        messages.push({ role: "user", content });
        save();
        render();
        setBusy(true);

        try {
          const response = await fetch("/api/troll-chat", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ messages })
          });

          if (!response.ok || !response.body) {
            let message = await response.text();

            try {
              message = JSON.parse(message)?.error?.message ?? message;
            } catch {
              message = message || "OpenRouter did not answer.";
            }

            throw new Error(message);
          }

          const reader = response.body.getReader();
          const decoder = new TextDecoder();

          while (true) {
            const { done, value } = await reader.read();

            if (done) {
              break;
            }

            appendAssistantChunk(decoder.decode(value, { stream: true }));
          }
        } catch (error) {
          errorEl.textContent =
            error instanceof Error && error.message
              ? error.message
              : "TROLL LINE BROKE. TRY AGAIN.";
          messages.push({
            role: "assistant",
            content: "The pipe exploded, obviously. Try again."
          });
          save();
          render();
        } finally {
          setBusy(false);
          promptEl.focus();
        }
      });

      promptEl.addEventListener("keydown", (event) => {
        if (event.key === "Enter" && !event.shiftKey) {
          event.preventDefault();
          form.requestSubmit();
        }
      });

      window.addEventListener("pointerdown", () => startAudio(true), { once: true });
      window.addEventListener("keydown", () => startAudio(true), { once: true });
      window.addEventListener("focus", keepAudioAlive);
      document.addEventListener("visibilitychange", keepAudioAlive);
      audio.addEventListener("loadedmetadata", () => {
        audio.currentTime = audioStartSeconds;
      });
      load();
      startAudio();
      setInterval(keepAudioAlive, 1800);
    </script>
  </body>
</html>
